GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
GOOGLE_MAPS_API_KEY=
FIRECRAWL_API_KEY=

# Optional AI SDK / Vercel AI Gateway settings.
# If unset, the CLI can still run in heuristic mode with --no-ai or --mock.
AI_MODEL=openai/gpt-5.4
DISABLE_AI=false

# Used by api/cron/scan.ts and Vercel cron.
CRON_SECRET=change-me
DEFAULT_AREA=Kent
DEFAULT_RADIUS_MILES=5
DEFAULT_COUNTY=Kent
DEFAULT_LIMIT_PER_TYPE=2
DEFAULT_MAX_SITES=20
DEFAULT_SPACE_TYPES=supermarket car parks,retail parks,petrol stations / forecourts,council car parks
REPORT_OUT_DIR=/tmp/biffpoc-runs
WEB_OUT_DIR=runs/web
PORT=4173
